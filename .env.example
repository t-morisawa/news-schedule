# 通知先Webhook (どちらか一方を設定)
# Discord
DISCORD_WEBHOOK_URL=

# Slack (Incoming Webhook)
SLACK_WEBHOOK_URL=

# 任意: 取得件数の上限（各ソース、デフォルト: 5）
MAX_ITEMS_PER_SOURCE=5

# 任意: AI関連と判定するキーワードのカンマ区切り（未設定で内蔵デフォルト）
AI_KEYWORDS=

# 任意: ドライラン（Webhookに投げない）。1で有効
DRY_RUN=

# 任意: タイムアウト（ms） デフォルト30000
SCRAPE_TIMEOUT_MS=30000
